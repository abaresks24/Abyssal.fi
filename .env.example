# ── Pacifica API ─────────────────────────────────────────────────────────────
# Get your API key from the Pacifica Builder Program dashboard
PACIFICA_API_KEY=your_pacifica_api_key_here
PACIFICA_API_BASE_URL=https://api.pacifica.finance
PACIFICA_WS_BASE_URL=wss://ws.pacifica.finance

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
ANCHOR_WALLET=~/.config/solana/id.json
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com

# Keeper wallet (separate from authority)
KEEPER_KEYPAIR_PATH=~/.config/solana/keeper.json

# ── Smart Contract ────────────────────────────────────────────────────────────
PROGRAM_ID=HBop4Q8KgmDVqE2TBFJsxGUXFweTXFsH5JeNMrpQsRXH
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU  # devnet USDC

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_PROGRAM_ID=HBop4Q8KgmDVqE2TBFJsxGUXFweTXFsH5JeNMrpQsRXH
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
